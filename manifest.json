{
  "manifest_version": 3,
  "name": "CanvasExportTool4u Unified Toolkit",
  "version": "1.0.0",
  "description": "Canvas Page Saver + DRM Debugger 통합 확장",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "merged_background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "canvas_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.CanvasExportTool4u.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": [
        "drm_content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "CanvasExportTool4u Unified Toolkit",
    "default_popup": "merged_popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "drm_page_world.js"
      ],
      "matches": [
        "*://*.CanvasExportTool4u.com/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ]
    }
  ],
  "devtools_page": "drm_devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
